{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2020"],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "incremental": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": ["node", "@cucumber/cucumber"]
    },
    "include": ["**/*.ts", "features/**/*.ts"],
    "exclude": ["node_modules", "dist", "coverage", "coverage-cucumber", "**/*.test.ts", "__tests__/**/*.ts"]
}
