{
    "name": "mermaid-codegen",
    "version": "1.1.23",
    "main": "./dist/index.js",
    "bin": {
        "mermaid-codegen": "./dist/index.js"
    },
    "files": [
        "dist",
        "Templates"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/ReneLombard/mermaid-codegen"
    },
    "scripts": {
        "build": "npm run process-jison && tsc",
        "build:cucumber": "npm run process-jison && tsc -p tsconfig.cucumber.json",
        "process-jison": "node -r ts-node/register processJison.ts",
        "start": "npm run build && node dist/index.js",
        "dev": "ts-node index.ts",
        "test": "npm run process-jison && jest",
        "test:watch": "npm run process-jison && jest --watch",
        "test:coverage": "npm run process-jison && jest --coverage",
        "test:ci": "npm run process-jison && jest --ci --coverage --watchAll=false",
        "test:cucumber": "npm run build:cucumber && cucumber-js",
        "test:cucumber:docs-parity": "npm run build:cucumber && cucumber-js --tags \"@docs-parity\"",
        "test:cucumber:watch": "npm run build:cucumber && cucumber-js --watch",
        "test:integration": "npm run test:cucumber",
        "lint:deadcode": "eslint . --ext .ts --max-warnings=0",
        "lint:strict-unused": "tsc --noEmit --noUnusedLocals --noUnusedParameters -p tsconfig.deadcode.json",
        "lint:deps": "depcheck --ignores=\"@types/chokidar,@types/commander,@types/fs-extra,@types/handlebars,@types/jest,@types/js-yaml,@types/node,@types/yamljs,ts-jest,ts-node\"",
        "check:deadcode": "npm run lint:deadcode && npm run lint:strict-unused && npm run lint:deps",
        "transform": "npm run build && node dist/index.js transform -i ./mermaid.md -o ../output/yml -n Company.VTC",
        "generate:code": "npm run build && node dist/index.js generate -i ../output/yml -o ../output/code --templates \"./Templates/C#\"",
        "generate:docs": "npm run build && node dist/index.js generate -i ../output/yml -o ../output/docs --templates \"./Templates/Documentation\"",
        "watch": "npm run build && node dist/index.js watch -m ./ -y \"../output/yml\" -o \"../output/code\" --templates \"./Templates/C#\" -n Company.VTC"
    },
    "dependencies": {
        "chokidar": "^4.0.3",
        "commander": "^13.1.0",
        "handlebars": "^4.7.8",
        "jison": "^0.4.18",
        "js-yaml": "^4.1.0",
        "yamljs": "^0.3.0"
    },
    "devDependencies": {
        "@cucumber/cucumber": "^12.6.0",
        "@types/chokidar": "^2.1.3",
        "@types/commander": "^2.12.2",
        "@types/fs-extra": "^11.0.4",
        "@types/handlebars": "^4.0.40",
        "@types/jest": "^29.5.12",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^24.3.0",
        "@types/yamljs": "^0.2.34",
        "@typescript-eslint/eslint-plugin": "^8.46.0",
        "@typescript-eslint/parser": "^8.46.0",
        "depcheck": "^1.4.7",
        "eslint": "^8.57.1",
        "eslint-plugin-unused-imports": "^4.2.0",
        "fs-extra": "^11.3.3",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2"
    }
}
